# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID(s) — comma-separated for multiple groups/channels
TELEGRAM_CHAT_ID=your_chat_id_here


# Notion Integration (https://www.notion.so/my-integrations)
NOTION_API_KEY=ntn_your_integration_secret_here

# Notion Trade Journal Database ID (from database URL)
NOTION_TRADE_DB_ID=your_database_id_here


